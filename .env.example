# ============================================================================
# A3 v3 环境变量配置
# 复制此文件为 .env 并填入你自己的 API Key
#   cp .env.example .env
# ============================================================================

# ---- 主力模型选择（默认 deepseek） ----
# 可选: deepseek | qwen | moonshot | glm | baichuan
# 改了这里，整个系统自动切换对应模型
PRIMARY_MODEL=deepseek

# ============================================================================
# 以下选一个填即可。系统已预置星火作为兜底，什么都不填也能用。
# 建议填 DeepSeek（充值 10 元用很久）。
# ============================================================================

# ---- DeepSeek（推荐 ⭐） ----
# 注册: https://platform.deepseek.com -> API Keys -> 创建新 Key
DEEPSEEK_API_KEY=你的Key填这里
# DEEPSEEK_MODEL=deepseek-chat

# ---- 通义千问（阿里云） ----
# 注册: https://dashscope.console.aliyun.com -> API-Key 管理 -> 创建
# QWEN_API_KEY=你的Key填这里
# QWEN_MODEL=qwen-plus

# ---- 月之暗面 Kimi（长文本专家） ----
# 注册: https://platform.moonshot.cn -> API Keys -> 创建
# MOONSHOT_API_KEY=你的Key填这里
# MOONSHOT_MODEL=moonshot-v1-8k

# ---- 智谱 GLM（清华系，glm-4-flash 免费） ----
# 注册: https://open.bigmodel.cn -> API Keys -> 复制
# GLM_API_KEY=你的Key填这里
# GLM_MODEL=glm-4-flash

# ---- 百川智能 ----
# 注册: https://platform.baichuan-ai.com -> API Keys -> 创建
# BAICHUAN_API_KEY=你的Key填这里
# BAICHUAN_MODEL=Baichuan4-Turbo

# ---- 讯飞星火（系统已预置，不需要配，可选覆盖） ----
# SPARK_API_KEY=你的Key
# SPARK_API_SECRET=你的Secret
# SPARK_APPID=你的APPID
